# ── Alpaca 帳戶設定 ─────────────────────────────────────
# 主帳戶 API Key（paper trading）
ALPACA_KEY_1=your_api_key_here
ALPACA_SECRET_1=your_api_secret_here

# ── Email 通知設定 ────────────────────────────────────────
# Gmail 建議使用「應用程式密碼」
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# 收件人 Email
NOTIFY_EMAIL=your_email@gmail.com
